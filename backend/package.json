{
  "name": "med-bot-backend",
  "version": "1.0.0",
  "description": "Backend for MediChat - AI-powered medical triage support app",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "start": "tsx src/index.ts",
    "ingest": "tsx scripts/ingest-knowledge.ts",
    "validate-drafts": "tsx scripts/validate-drafts.ts",
    "promote-draft": "tsx scripts/promote-draft.ts",
    "seed-rules": "tsx scripts/seed-clinical-rules.ts",
    "setup": "npm run seed-rules && npm run ingest",
    "deploy-index": "tsx scripts/deploy-vector-index.ts",
    "test-chat": "tsx scripts/test-chat.ts"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@vercel/connect": "^0.3.2",
    "ai": "^7.0.18",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "eve": "^0.22.1",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "openai": "^4.55.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^7.0.1-rc"
  }
}
