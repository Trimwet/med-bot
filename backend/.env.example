# Server
PORT=3000
NODE_ENV=development

# Auth (trusted-agent bypass, pattern reused from TADA VTU)
CORE_SECRET=change-me

# MongoDB (single instance: sessions_collection + knowledge_collection)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB_NAME=medbot

# Embeddings / LLM
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
